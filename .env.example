# GitHub Pages subdirectory deployment (before custom domain)
# Set to '/everyday-data' while using zacharylong.github.io/everyday-data
# Set to '' (empty) once custom domain is active
NEXT_PUBLIC_BASE_PATH=

# Full site URL (used for canonical URLs, OG tags, sitemap)
# Set to 'https://zacharylong.github.io/everyday-data' before custom domain
# Set to 'https://everydaydata.show' once custom domain is active
NEXT_PUBLIC_SITE_URL=https://everydaydata.show
